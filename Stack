// Next Smalller element
    vector<int>NSI(vector<int>&arr){
            int n=arr.size();
        stack<int>st;
        vector<int>ans(n,n);
        for(int i=n-1;i>=0;i--){
            while(!st.empty() && arr[i]<=arr[st.top()]){
                st.pop();
            }
            if(!st.empty()){
               ans[i] = arr[st.top()];
            }
           st.push(i);
        }
        return ans;
    }
