// Previous Smalller element
vector<int>PSI(vector<int>&arr){
        int n=arr.size();
        stack<int>st;
        vector<int>ans(n,-1);
        for(int i=0;i<n;i++){
            while(!st.empty() && arr[i]<arr[st.top()]){
                st.pop();
            }
            if(!st.empty()){
                ans[i] = arr[st.top()];
            }
           st.push(i);
        }
        return ans;
    }
